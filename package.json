{
  "name": "clirank-mcp-server",
  "version": "0.7.5",
  "description": "MCP server for API discovery and recommendations: help Claude Code, Codex, Cursor, Cline, and other coding agents choose APIs with current CLIRank data instead of stale model memory",
  "type": "module",
  "bin": {
    "clirank-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "mcpName": "io.github.alexanderclapp/clirank",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "api-discovery",
    "api-recommendation",
    "api-selection",
    "api-ranking",
    "api-directory",
    "api-docs",
    "coding-agents",
    "ai-agent",
    "agent-tools",
    "agentic-coding",
    "claude-code",
    "claude-mcp",
    "cursor",
    "codex",
    "cline",
    "windsurf",
    "continue",
    "developer-tools",
    "sdk",
    "saas",
    "npm",
    "cli",
    "clirank"
  ],
  "author": "CLIRank",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexanderclapp/clirank-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "files": [
    "dist",
    "README.md",
    "llms-install.md"
  ],
  "homepage": "https://clirank.dev",
  "bugs": {
    "url": "https://clirank.dev/hello",
    "email": "alex@clirank.dev"
  }
}
